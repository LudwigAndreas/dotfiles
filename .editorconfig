# top-most EditorConfig file
root = true

# All files
[*]
charset = utf-8
end_of_line = lf
indent_style = space
trim_trailing_whitespace = true
insert_final_newline = true

# C++ files
[*.cpp, *.cc, *.h, *.hpp]
indent_size = 2

# CMake files
[CMakeLists.txt, *.cmake]
indent_size = 2

# Ignore min/max headers
[*.h]
exclude_patterns = *_min.h, *_max.h